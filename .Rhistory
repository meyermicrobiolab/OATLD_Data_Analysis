ps
summarize_phyloseq(ps)
#filter based on prevalence and max relative abundance
#Prevalence of a given ASV
prevdf = apply(X = otu_table(ps),
MARGIN = ifelse(taxa_are_rows(ps), yes = 1, no = 2),
FUN = function(x){sum(x > 0)})
#maximum relative abundance of each ASV
relabun = apply(otu_table(ps_ra),
MARGIN = ifelse(taxa_are_rows(ps_ra), yes = 1, no = 2),
max)
#Get relative abundance
ps_ra<- transform_sample_counts(ps, function(OTU) OTU/sum(OTU))
#filter based on prevalence and max relative abundance
#Prevalence of a given ASV
prevdf = apply(X = otu_table(ps),
MARGIN = ifelse(taxa_are_rows(ps), yes = 1, no = 2),
FUN = function(x){sum(x > 0)})
#maximum relative abundance of each ASV
relabun = apply(otu_table(ps_ra),
MARGIN = ifelse(taxa_are_rows(ps_ra), yes = 1, no = 2),
max)
#create prev and relabun data table w/ taxonomy
prevdf = data.frame(Prevalence = prevdf,
MaxRelAbundance = relabun,
tax_table(ps))
# Execute rel abun and prev filter, using `prune_taxa()` function
# Define abundance and prevelence threshold for taxa
# must be >= 0.1% in at least 1 sample, and be in 3 or more samples
relAbundanceThreshold <- 0.001
prevalenceThreshold <- 3
keepTaxa <- rownames(prevdf)[(prevdf$MaxRelAbundance >= relAbundanceThreshold &
prevdf$Prevalence >= prevalenceThreshold)]
ps_f1 <- prune_taxa(keepTaxa, ps) #ps filt obj
#Write out filtered Dataset Table
otu_ps_f1 = as(otu_table(ps_f1), "matrix")
taxon_ps_f1 = as(tax_table(ps_f1), "matrix")
write.table(otu_ps_f1,"silva_nochloronomito_otu_table_ps_f1.txt",sep="\t",col.names=NA)
write.table(taxon_ps_f1,"silva_nochloronomito_taxa_table_ps_f1.txt",sep="\t",col.names=NA)
#What Sequences/ASVs Are Actually In the Blanks?
ps_blanks<- subset_samples(ps, Condition =="blank")
ps_blanks_pruned <- prune_taxa(taxa_sums(ps_blanks) > 0, ps_blanks)
ps_blanks_pruned
View(ps_blanks_pruned@tax_table)
write.csv(ps_blanks_pruned@tax_table, "ASVs_in_blanks.csv")
#Visualize library size
df <- as.data.frame(sample_data(ps)) # Put sample_data into a ggplot-friendly data.frame
df$LibrarySize <- sample_sums(ps)
df <- df[order(df$LibrarySize),]
df$Index <- seq(nrow(df))
ggplot(data=df, aes(x=Index, y=LibrarySize, color=Condition)) + geom_point()
sample_data(ps)$is.neg <- sample_data(ps)$Condition == "blank"
contamdf.prev <- isContaminant(ps, method="prevalence", neg="is.neg")
library(decontam)
contamdf.prev <- isContaminant(ps, method="prevalence", neg="is.neg")
table(contamdf.prev$contaminant)
head(which(contamdf.prev$contaminant))
contamdf.prev05 <- isContaminant(ps, method="prevalence", neg="is.neg", threshold=0.5)
table(contamdf.prev05$contaminant)
contam_list<- contamdf.prev05[contamdf.prev05$contaminant=="TRUE",]
contam_list_w_tax<- merge(contam_list, taxon, by = "row.names")
write.csv(contam_list_w_tax, "true_contaminants.csv")
ps.pa <- transform_sample_counts(ps, function(abund) 1*(abund>0))
ps.pa.neg <- prune_samples(sample_data(ps.pa)$Condition == "blank", ps.pa)
ps.pa.pos <- prune_samples(sample_data(ps.pa)$Condition == "DD" | sample_data(ps.pa)$Condition == "HD" | sample_data(ps.pa)$Condition == "HH", ps.pa)
ps_no_contam <- prune_taxa(!contamdf.prev$contaminant, ps)
ps_no_contam <- subset_samples(ps_no_contam, Condition != "blank")
ps_no_contam_ra<- transform_sample_counts(ps_no_contam, function(OTU) OTU/sum(OTU))
ps_no_contam
summarize_phyloseq(ps_no_contam)
#filter based on prevalence and max relative abundance
#Prevalence of a given ASV
prevdf = apply(X = otu_table(ps_no_contam),
MARGIN = ifelse(taxa_are_rows(ps_no_contam), yes = 1, no = 2),
FUN = function(x){sum(x > 0)})
#maximum relative abundance of each ASV
relabun = apply(otu_table(ps_no_contam_ra),
MARGIN = ifelse(taxa_are_rows(ps_no_contam_ra), yes = 1, no = 2),
max)
#create prev and relabun data table w/ taxonomy
prevdf = data.frame(Prevalence = prevdf,
MaxRelAbundance = relabun,
tax_table(ps_no_contam))
# Execute rel abun and prev filter, using `prune_taxa()` function
# Define abundance and prevelence threshold for taxa
# must be >= 0.1% in at least 1 sample, and be in 2 or more samples
relAbundanceThreshold <- 0.001
prevalenceThreshold <- 2
keepTaxa <- rownames(prevdf)[(prevdf$MaxRelAbundance >= relAbundanceThreshold &
prevdf$Prevalence >= prevalenceThreshold)]
ps_f2 <- prune_taxa(keepTaxa, ps_no_contam) #ps filt obj
#Write out filtered Dataset Table
otu_ps_f2 = as(otu_table(ps_f2), "matrix")
taxon_ps_f2 = as(tax_table(ps_f2), "matrix")
samples_ps_f2<- as(sample_data(ps_f2), "matrix")
write.table(otu_ps_f2,"silva_nochloronomito_otu_table_ps_f2.txt",sep="\t",col.names=NA)
write.table(taxon_ps_f2,"silva_nochloronomito_taxa_table_ps_f2.txt",sep="\t",col.names=NA)
ps_f2
ps_f2_ra<- transform_sample_counts(ps_f2, function(OTU) OTU/sum(OTU))
ps_f2
ps_f2_HH_DD<- subset_samples(ps_f2, Condition == "HH" | Condition == "DD")
ps_f2_HH_DD
ps_f2_HH_DD_pruned <- prune_taxa(taxa_sums(ps_f2_HH_DD) > 0, ps_f2_HH_DD)
ps_f2_HH_DD_pruned
library(vegan)
###############################################
#CLAM Test PS
###############################################
otu_table <- as.data.frame(otu_table(ps_f2_HH_DD_pruned))
sample_data <- as.data.frame(sample_data(ps_f2_HH_DD_pruned))
# Assuming 'group' is a column in your sample data
env_var <- sample_data$Condition
clam_results_ps <- vegan::clamtest(otu_table, env_var, alpha = 0.05, specialization = 2/3)
print(clam_results_ps)
#Attach taxonomic data to ASVs
tax_table <- as.data.frame(tax_table(ps_f2_HH_DD_pruned))
tax_table$Species<- rownames(tax_table)
clam_ps_w_tax<- merge(clam_results_ps, tax_table, by = "Species")
###How many of each group?
#Subset by Generalists
clam_ps_w_tax_gen<- clam_ps_w_tax[clam_ps_w_tax$Classes=="Generalist",]
nrow(clam_ps_w_tax_gen)
#Subset by Healthy Specialists
clam_ps_w_tax_hh<- clam_ps_w_tax[clam_ps_w_tax$Classes=="Specialist_HH",]
nrow(clam_ps_w_tax_hh)
#Subset by Disease Specialists
clam_ps_w_tax_dd<- clam_ps_w_tax[clam_ps_w_tax$Classes=="Specialist_DD",]
nrow(clam_ps_w_tax_dd)
#Subset by Too Rare
clam_ps_w_tax_rare<- clam_ps_w_tax[clam_ps_w_tax$Classes=="Too_rare",]
nrow(clam_ps_w_tax_rare)
print(clam_results_ps)
summary(clam_results_ps)
c("DD" = "#d1495b", "HD" = "#edae49", "HH" = "#00798c")
colors <- c("Generalist" = "gray",
"Specialist_HH" = "#00798c",
"Specialist_DD" = "#d1495b",
"Too_Rare" = "black")
labels<- c("Generalist", "Specialist Healthy", "Specialist Diseased", "Too Rare")
sig_dif_hh_dd$ASV
