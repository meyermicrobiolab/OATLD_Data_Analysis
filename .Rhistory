library(ggplot2)
library(vegan)
colors <- c("Generalist" = "gray",
"Specialist Healthy" = "#00798c",
"Specialist_Diseased" = "#d1495b",
"Too_Rare" = "black")
plot(clam_results_ps, xlab = "Relative abundance +1 in Diseased samples", ylab = "Relative abundance +1 in Healthy samples",
pch = c(1,16,16,1), col=colors, col.lines = c("black", "black", "black"),
lty = c(2,2,2), cex=1.5, position = "topleft")
legend("topleft",legend = labels, pch = c(1,16,16,1), col=colors)
data(mite)
data(mite.env)
sol <- with(mite.env, clamtest(mite, Shrub=="None", alpha=0.005))
summary(sol)
head(sol)
plot(sol)
summary(clam_results_ps)
print(clam_results_ps)
plot(clam_results_ps, xlab = "Diseased samples", ylab = "Healthy samples",
pch = c(1,16,16,1), col=colors, col.lines = c("black", "black", "black"),
lty = c(2,2,2), cex=1.5, position = "topleft")
legend("topleft",legend = labels, pch = c(1,16,16,1), col=colors)
